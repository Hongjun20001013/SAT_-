\begin{frame}{Question: Types of Solutions}
\small
In the given system of equations, $p$ is a constant. If the system has no solution, what is the value of $p$?
\[
\frac{3}{2}y - \frac{1}{4}x = \frac{2}{3} - \frac{3}{2}y
\]
\[
\frac{1}{2}x + \frac{3}{2} = py + \frac{9}{2}
\]
\end{frame}
\begin{frame}{Solution}
\small

\textbf{Step 1: Simplify both equations}

First equation:
\[
\frac{3}{2}y - \frac{1}{4}x = \frac{2}{3} - \frac{3}{2}y
\Rightarrow \frac{3}{2}y + \frac{3}{2}y - \frac{1}{4}x = \frac{2}{3}
\Rightarrow 3y - \frac{1}{4}x = \frac{2}{3}
\]

Second equation:
\[
\frac{1}{2}x + \frac{3}{2} = py + \frac{9}{2}
\Rightarrow \frac{1}{2}x + \frac{3}{2} - \frac{9}{2} = py
\Rightarrow \frac{1}{2}x - 3 = py
\]

\textbf{Step 2: Write both in standard form}

From the first:
\[
\frac{1}{4}x - 3y = -\frac{2}{3}
\]

From the second:
\[
\frac{1}{2}x - py = 3
\]

\textbf{Step 3: No solution condition}

To have no solution, the lines must be parallel — same slope, different intercepts.

\[
\frac{\frac{1}{4}}{-3} = \frac{\frac{1}{2}}{-p}
\Rightarrow \frac{1}{4} \cdot (-p) = \frac{1}{2} \cdot (-3)
\Rightarrow -\frac{p}{4} = -\frac{3}{2}
\Rightarrow \frac{p}{4} = \frac{3}{2}
\Rightarrow p = 6
\]

\[
\boxed{p = 6}
\]
\end{frame}

\begin{frame}{System of Equations — No Solution}
    \textbf{Given:}
    \[
    \begin{aligned}
        4x - 6y &= 10y + 2 \\
        ty &= \frac{1}{2} + 2x
    \end{aligned}
    \]
    In the given system of equations, $t$ is a constant. If the system has no solution, what is the value of $t$?
\end{frame}


\begin{frame}{Solution}
    \small
    \textbf{Step 1: Rearrange both equations}
    \begin{itemize}
        \item Move all terms to one side in the first equation:
        \[
        4x - 6y - 10y = 2 \Rightarrow 4x - 16y = 2
        \]
        \item Rearranged second equation:
        \[
        ty = \frac{1}{2} + 2x \Rightarrow -2x + ty = \frac{1}{2}
        \]
    \end{itemize}

    \textbf{Step 2: Identify slope condition for no solution}
    \begin{itemize}
        \item Coefficients must give the same slope:
        \[
        \frac{4}{-16} = \frac{-2}{t} \Rightarrow -\frac{1}{4} = \frac{-2}{t}
        \Rightarrow t = 8
        \]
    \end{itemize}

    \begin{center}
        \textbf{Final Answer: } $ \boxed{t = 8} $
    \end{center}
\end{frame}



