\begin{frame}{System of Equations — Parametric Point}
    \textbf{Given:}
    \[
    \begin{aligned}
        2x + 3y &= 7 \\
        10x + 15y &= 35
    \end{aligned}
    \]

    For each real number $r$, which of the following points lies on the graph of \textbf{each} equation in the $xy$-plane?

    \begin{itemize}
        \item[(A)] $\left( \frac{r}{5} + 7,\ -\frac{r}{5} + 35 \right)$
        \item[(B)] $\left( -\frac{3r}{2} + \frac{7}{2},\ r \right)$
        \item[(C)] $\left( r,\ \frac{2r}{3} + \frac{7}{3} \right)$
        \item[(D)] $\left( r,\ -\frac{3r}{2} + \frac{7}{2} \right)$
    \end{itemize}
\end{frame}

\begin{frame}{Solution}
    \small
    \textbf{Step 1: Notice the system of equations}
    \[
    \begin{aligned}
        2x + 3y &= 7 \\
        10x + 15y &= 35
    \end{aligned}
    \]

    \begin{itemize}
        \item Second equation is a multiple of the first: $5(2x + 3y) = 10x + 15y = 35$.
        \item Therefore, both equations are equivalent — they represent the same line.
    \end{itemize}

    \textbf{Step 2: Pick a parametric form}
    \begin{itemize}
        \item Solve $2x + 3y = 7$ for $x$:
        \[
        x = -\frac{3}{2}y + \frac{7}{2}
        \]
        \item Let $y = r$, then:
        \[
        x = -\frac{3}{2}r + \frac{7}{2}
        \]
        \item So the point on the line is $\left(  -\frac{3}{2}r + \frac{7}{2},r \right)$
    \end{itemize}

    \textbf{Final Answer:} $\boxed{\text{B.}}$  

\end{frame}


\begin{frame}{Another Solution — Answer: B}
    \small
    \textbf{Step 1: Observe the system of equations}
    \[
    \begin{aligned}
        2x + 3y &= 7 \\
        10x + 15y &= 35
    \end{aligned}
    \]

    \begin{itemize}
        \item Second equation is a multiple of the first:
        \[
        5(2x + 3y) = 10x + 15y = 35
        \]
        \item So both equations describe the same line.
    \end{itemize}

    \textbf{Step 2: Plug the coordinates of each choice into the first equation}

    \begin{itemize}
        \item Choice (B): $x = -\dfrac{3r}{2} + \dfrac{7}{2}$,\quad $y = r$
        \item Plug into: $2x + 3y = 7$
        \[
        2\left( -\dfrac{3r}{2} + \dfrac{7}{2} \right) + 3r = -3r + 7 + 3r = 7
        \]
        \item True! So this point lies on the line.
    \end{itemize}

    \textbf{Answer:} $\boxed{\text{B}}$
\end{frame}

