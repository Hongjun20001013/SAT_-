\begin{frame}{Types of Solutions}
  \begin{itemize}
    \item \textbf{One solution:} The lines intersect at one point.
    \item \textbf{No solution:} The lines are parallel and never intersect.
    \item \textbf{Infinitely many solutions:} The lines are identical.
  \end{itemize}
