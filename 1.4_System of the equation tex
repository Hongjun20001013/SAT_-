        \includegraphics[width=0.3\linewidth]{E15.png}
    \end{center}
\end{frame}



    
\end{frame}



% Slide: Solving by Graphing
\begin{frame}{Solving by Graphing}
  \begin{itemize}
    \item Graph both equations on the coordinate plane.
    \item The point of intersection is the solution.
    \item This method is visual but not always accurate without graphing tools.
  \end{itemize}

  \textbf{Example:}
  \[
  \begin{cases}
  y = 2x + 1 \\
  y = -x + 4
  \end{cases}
  \quad \Rightarrow \quad \text{Intersect at } (1, 3)
  \]
\end{frame}

% Slide: Solving by Substitution
\begin{frame}{Solving by Substitution}
  \textbf{Steps:}
  \begin{enumerate}
    \item Solve one equation for one variable.
    \item Substitute that expression into the other equation.
    \item Solve for the remaining variable, then back-substitute to find the other.
  \end{enumerate}

  \textbf{Example:}
  \[
  \begin{cases}
  y = 3x + 2 \\
  2x + y = 16
  \end{cases}
  \Rightarrow 2x + (3x + 2) = 16 
  \]
\end{frame}

% Slide: Solving by Elimination
\begin{frame}{Solving by Elimination}
  \textbf{Steps:}
  \begin{enumerate}
    \item Align both equations.
    \item Multiply one or both equations to make coefficients cancel.
    \item Add/subtract to eliminate one variable.
    \item Solve for one variable, then substitute to find the other.
  \end{enumerate}

  \textbf{Example:}
  \[
  \begin{cases}
  3x + 2y = 16 \\
  5x - 2y = 4
  \end{cases}
  \Rightarrow 8x = 20 \Rightarrow x = 2, \ y = 5
  \]
\end{frame}


\begin{frame}{Question: Solve for \( y \)}
    Solve for \( y \) in the system of equations:
    \[
    \begin{aligned}
        -x + y &= -3.5 \\
        x + 3y &= 9.5
    \end{aligned}
    \]
    If \( (x, y) \) satisfies the system above, what is the value of \( y \)?
\end{frame}

% --- Solution Slide ---
\begin{frame}{Solution}
\small
\begin{columns}
    % Left column for solution steps
    \column{0.65\textwidth}
    
    \textbf{Step 1: Solve for \( x \)}
    \begin{itemize}
        \item Rewrite the first equation for \( x \):
        \[
        x = y + 3.5
        \]
        \item Substitute into the second equation:
        \[
        (y + 3.5) + 3y = 9.5
        \]
    \end{itemize}

    \textbf{Step 2: Solve for \( y \)}
    \begin{itemize}
        \item Simplify:
        \[
        4y + 3.5 = 9.5
        \]
        \item Divide by 4:
        \[
        y = \frac{6}{4} = 1.5
        \]
    \end{itemize}

